# Agent Chat de_src 示例 — API 配置模板
# 复制此文件为 .env.test 并填入你的 API 信息。
# .env.test 已被 .gitignore 排除，不会提交到仓库。
#
# 运行方式：
#   cd dart/example
#   flutter run --dart-define-from-file=.env.test -t lib/main_de_src.dart

API_KEY=YOUR_API_KEY
API_BASE_URL=https://api.deepseek.com
API_MODEL_ID=deepseek-v4-flash
API_SUPPORT_JSON=true
